def _gcs_ls(path: str) -> list[str]:
    """Return `gsutil ls <path>` lines, or empty list if path doesn't exist."""
    r = subprocess.run(
        ["gsutil", "ls", path], capture_output=True, text=True, timeout=60,
    )
    if r.returncode != 0:
        return []
    return [l.strip() for l in r.stdout.split("\n") if l.strip()]


def _latest_ckpt_step(run_label: str) -> int | None:
    """Return the latest step-N under the run's checkpoint dir, or None."""
    base = f"{GCS_BUCKET}/results/{run_label}/checkpoints/{run_label}"
    steps = []
    for line in _gcs_ls(f"{base}/"):
        m = re.search(r"/step-(\d+)/?$", line)
        if m:
            steps.append(int(m.group(1)))
    return max(steps) if steps else None


@cli.command("train")
@click.option("-r", "--resume", "resume_mode", is_flag=True,
              help="resume existing run (same LABEL → Levanter auto-discovers latest ckpt + continues with intact optimizer state)")
@click.option("-D", "--data-label", default="train-full-lmq-v2-lat",
              help="TOMAT_LABEL (data subdir under tokenized/)")
@click.option("-m", "--model", default="200M", help="TOMAT_MODEL preset")
@click.option("-T", "--tpu", default="v6e-16", help="iris --tpu")
@click.option("-s", "--steps", required=True, type=int, help="TOMAT_STEPS")
@click.option("-b", "--batch-size", default=128, type=int, help="TOMAT_BATCH_SIZE")
@click.option("--seed", default=42, type=int, help="TOMAT_SEED")
@click.option("--lmq-path", default=None, help="TOMAT_LMQ_PATH (default = repo LMQ_PATH constant)")
@click.option("--lr", default=3e-4, type=float, help="TOMAT_LR")
@click.option("--lr-schedule", "lr_schedule", default="constant",
              help="TOMAT_LR_SCHEDULE (constant|cosine|linear|inv_sqrt)")
@click.option("--warmup", default=0.05, type=float, help="TOMAT_WARMUP fraction")
@click.option("--cooldown", default=None, type=float, help="TOMAT_COOLDOWN fraction (WSD)")
@click.option("--val-seqs", default=256, type=int, help="TOMAT_VAL_SEQS")
@click.option("--steps-per-eval", default=None, type=int, help="TOMAT_STEPS_PER_EVAL")
@click.option("--grad-ckpt/--no-grad-ckpt", default=True, help="TOMAT_GRADIENT_CHECKPOINTING (default True; pass --no-grad-ckpt to disable for MFU experiments)")
@click.option("--profile/--no-profile", default=True, help="TOMAT_PROFILE")
@click.option("--density-loss", default="emd", help="TOMAT_DENSITY_LOSS_TYPE (emd|l1)")
@click.option("--density-only/--density-add", default=True, help="TOMAT_DENSITY_ONLY_LOSS")
@click.option("--cpu", default=32, type=int, help="iris --cpu")
@click.option("--memory", default="64GB", help="iris --memory")
@click.option("-e", "--env", "extra_env", multiple=True, help="extra env var KEY=VAL (repeatable)")
@click.option("--shuffle-window-blocks", type=int, default=0, help="TOMAT_SHUFFLE_WINDOW_BLOCKS; 0 = no shuffle (default), >0 = BlockShuffle window radius")
@click.option("--shuffle-io-block-size", type=int, default=0, help="TOMAT_SHUFFLE_IO_BLOCK_SIZE; 0 = auto from meta (M)")
@click.option("--share-cache/--no-share-cache", default=False, help="Share the levanter cache across runs over the same data (TOMAT_CACHE_DIR=gs://.../cache/<data_label>/). Default per-run for back-compat.")
@click.option("--watch-preempts/--no-watch-preempts", default=True, help="auto-fire `tomat preempts watch <LABEL>` in the background after launch (default on)")
@click.option("-f", "--force", is_flag=True, help="allow from-scratch overwrite of existing results dir")
@click.option("-d", "--dry-run", is_flag=True, help="print iris cmd without firing")
@click.argument("label")
def train(
    label: str,
    resume_mode: bool,
    data_label: str,
    model: str,
    tpu: str,
    steps: int,
    batch_size: int,
    seed: int,
    lmq_path: str | None,
    lr: float,
    lr_schedule: str,
    warmup: float,
    cooldown: float | None,
    val_seqs: int,
    steps_per_eval: int | None,
    grad_ckpt: bool,
    profile: bool,
    density_loss: str,
    density_only: bool,
    cpu: int,
    memory: str,
    extra_env: tuple[str, ...],
    shuffle_window_blocks: int,
    shuffle_io_block_size: int,
    share_cache: bool,
    watch_preempts: bool,
    force: bool,
    dry_run: bool,
):
    """Launch (or resume) a tomat training run.

    Modes:
      from-scratch (default)   new run with LABEL; errors if results dir exists
      --resume / -r            continue existing run (same LABEL); errors if
                               no checkpoints found. Native Levanter auto-
                               discovery loads the latest ckpt + optimizer
                               state intact.

    Warm-start (model-only load, fresh optimizer) is NOT a supported mode —
    it caused the 1B cont-from-4711 spike. If you want it back, add it as
    an explicit flag with safer LR defaults.
    """
    latest = _latest_ckpt_step(label)
    if resume_mode:
        if latest is None:
            err(f"--resume {label}: no step-* ckpts under "
                f"{GCS_BUCKET}/results/{label}/checkpoints/{label}/")
            sys.exit(1)
        print(f"[tomat train] resume mode: latest ckpt step-{latest} → "
              f"continuing to step {steps}")
    else:
        if latest is not None and not force:
            err(f"results dir for {label!r} already has step-{latest} ckpt; "
                f"use --resume to continue, or --force to overwrite")
            sys.exit(1)

    wandb_key = os.environ.get("WANDB_API_KEY", "<WANDB_API_KEY>")
    if not dry_run and wandb_key == "<WANDB_API_KEY>":
        err("WANDB_API_KEY not set in env")
        sys.exit(1)

    env_vars: list[tuple[str, str]] = [
        ("WANDB_API_KEY", wandb_key),
        ("TOMAT_LABEL", data_label),
        ("TOMAT_RESULTS_LABEL", label),
        ("TOMAT_MODEL", model),
        ("TOMAT_STEPS", str(steps)),
        ("TOMAT_BATCH_SIZE", str(batch_size)),
        ("TOMAT_SEED", str(seed)),
        ("TOMAT_LMQ_PATH", lmq_path or LMQ_PATH),
        ("TOMAT_DENSITY_LOSS_TYPE", density_loss),
        ("TOMAT_DENSITY_ONLY_LOSS", "1" if density_only else "0"),
        ("TOMAT_LR", str(lr)),
        ("TOMAT_LR_SCHEDULE", lr_schedule),
        ("TOMAT_WARMUP", str(warmup)),
        ("TOMAT_VAL_SEQS", str(val_seqs)),
        ("TOMAT_PROFILE", "1" if profile else "0"),
    ]
    if cooldown is not None:
        env_vars.append(("TOMAT_COOLDOWN", str(cooldown)))
    if steps_per_eval is not None:
        env_vars.append(("TOMAT_STEPS_PER_EVAL", str(steps_per_eval)))
    env_vars.append(("TOMAT_GRADIENT_CHECKPOINTING", "1" if grad_ckpt else "0"))
    if shuffle_window_blocks > 0:
        env_vars.append(("TOMAT_SHUFFLE_WINDOW_BLOCKS", str(shuffle_window_blocks)))
        if shuffle_io_block_size > 0:
            env_vars.append(("TOMAT_SHUFFLE_IO_BLOCK_SIZE", str(shuffle_io_block_size)))
    if share_cache:
        env_vars.append(("TOMAT_CACHE_DIR", f"{GCS_BUCKET}/cache/{data_label}/"))
    for kv in extra_env:
        if "=" not in kv:
            err(f"--env {kv!r}: expected KEY=VAL")
            sys.exit(1)
        k, v = kv.split("=", 1)
        env_vars.append((k, v))

    cmd = [
        "uv", "run", "iris", "--cluster=marin", "job", "run",
        "--tpu", tpu, "--enable-extra-resources",
        "--cpu", str(cpu), "--memory", memory,
    ]
    for k, v in env_vars:
        cmd += ["--env-vars", k, v]
    cmd += [
        "--no-wait", "--no-terminate-on-exit",
        "--job-name", label,
        "--", "python", "train_tomat_tpu.py",
    ]

    if dry_run:
        pretty = " ".join(
            "'<WANDB_API_KEY>'" if a == wandb_key else a for a in cmd
        )
        print(f"# {label} ({'resume' if resume_mode else 'from-scratch'})")
        print(f"  cd {MARIN_DIR}")
        print(f"  {pretty}")
        return

    r = subprocess.run(cmd, cwd=str(MARIN_DIR), capture_output=True, text=True)
    if r.returncode != 0:
        err(f"[FAIL launch {label}] rc={r.returncode}\n{r.stderr[-1000:]}")
        sys.exit(r.returncode)
    print(f"[launched {label} on {tpu}, {steps} steps"
          f"{f' (resume from step-{latest})' if resume_mode else ''}]")
    print(f"  wandb: https://wandb.ai/{WANDB_PROJECT}/runs/{label}")

    if watch_preempts:
        # Background-fire `tomat preempts watch <label>` so the wandb run
        # carries cluster/preemptions + cluster/preempts_delta from the
        # start. Per-run log file lives at tmp/preempts-<label>.log.
        Path("tmp").mkdir(exist_ok=True)
        watch_log = Path("tmp") / f"preempts-{label}.log"
        watch_proc = subprocess.Popen(
            [str(Path(__file__).resolve()), "preempts", "watch", label],
            stdout=open(watch_log, "ab"),
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )
        print(f"[preempts watch pid={watch_proc.pid} log={watch_log}]")


