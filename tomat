@cli.group()
def evals():
    """Mat-NMAE eval firing + harvesting."""


@evals.command("fire")
@click.option("-s", "--steps", required=True, help="comma-sep step list, e.g. 1000,2000,3000")
@click.option("-S", "--sets", default="val_200,train_200", help="comma-sep mat-sets")
@click.option("-l", "--eval-label", default="val-full-lmq-v2", help="TOMAT_LABEL for eval jobs (must match ckpt's tokenization, e.g. val-full-v3)")
@click.option("-m", "--model", default="200M", help="TOMAT_MODEL preset")
@click.option("-n", "--n-mats", default=200, type=int)
@click.option("-b", "--eval-batch", default=32, type=int)
@click.option("-t", "--tpu", default="v6e-8")
@click.option("--decoder", default="median")
@click.option("-d", "--dry-run", is_flag=True, help="print iris commands without executing")
@click.argument("run_label")
def evals_fire(
    run_label: str,
    steps: str,
    sets: str,
    eval_label: str,
    model: str,
    n_mats: int,
    eval_batch: int,
    tpu: str,
    decoder: str,
    dry_run: bool,
):
    """Fire mat-NMAE eval jobs against a run's GCS checkpoints.

    Pre-populates the watchdog FIRED files so a subsequent
    `tomat evals harvest <run>` will pick the harvested numbers up.
    Use --dry-run to print the iris commands without firing.
    """
    step_list = [int(s) for s in steps.split(",")]
    set_list = sets.split(",")
    for s in set_list:
        if s not in SPLITS:
            err(f"unknown mat-set {s!r}; known: {sorted(SPLITS)}")
            sys.exit(1)

    if not dry_run:
        TMP_DIR.mkdir(exist_ok=True)
        for s in set_list:
            (TMP_DIR / f"{run_label}-{s}-evals-fired.txt").write_text("")

    wandb_key = os.environ.get("WANDB_API_KEY", "<WANDB_API_KEY>")
    if not dry_run and wandb_key == "<WANDB_API_KEY>":
        err("WANDB_API_KEY not set in env")
        sys.exit(1)

    fired_total = 0
    for step in step_list:
        for s in set_list:
            jn = f"tomat-eval-{run_label}-{s}-step-{step}"
            split = SPLITS[s]
            ckpt = f"{GCS_BUCKET}/results/{run_label}/checkpoints/{run_label}/step-{step}"
            cmd = [
                "uv", "run", "iris", "--cluster=marin", "job", "run",
                "--tpu", tpu, "--enable-extra-resources",
                "--cpu", "32", "--memory", "64GB",
                "--env-vars", "WANDB_API_KEY", wandb_key,
                "--env-vars", "TOMAT_LABEL", eval_label,
                "--env-vars", "TOMAT_MODEL", model,
                "--env-vars", "TOMAT_CHECKPOINT", ckpt,
                "--env-vars", "TOMAT_LMQ_PATH", LMQ_PATH,
                "--env-vars", "TOMAT_EVAL_N_MATS", str(n_mats),
                "--env-vars", "TOMAT_EVAL_SKIP", "0",
                "--env-vars", "TOMAT_EVAL_BATCH", str(eval_batch),
                "--env-vars", "TOMAT_EVAL_DECODER", decoder,
                "--env-vars", "TOMAT_EVAL_MAT_SET", s,
                "--env-vars", "TOMAT_EVAL_SPLIT", split,
                "--no-wait", "--no-terminate-on-exit",
                "--job-name", jn,
                "--", "python", "eval_mat_nmae.py",
            ]
            if dry_run:
                # Print the cmd as a runnable shell line. Mask the actual
                # WANDB_API_KEY value with a literal placeholder.
                pretty = " ".join(
                    "'<WANDB_API_KEY>'" if a == wandb_key else a
                    for a in cmd
                )
                print(f"# {jn}")
                print(f"  cd {MARIN_DIR}")
                print(f"  {pretty}")
                print()
                fired_total += 1
                continue
            r = subprocess.run(cmd, cwd=str(MARIN_DIR), capture_output=True, text=True)
            if r.returncode != 0:
                err(f"[FAIL fire {jn}] rc={r.returncode}\n{r.stderr[-500:]}")
                continue
            print(f"[fired {jn}]")
            with open(TMP_DIR / f"{run_label}-{s}-evals-fired.txt", "a") as f:
                f.write(f"{step}\n")
            fired_total += 1

    suffix = " (dry-run)" if dry_run else ""
    print(f"\n[done firing {fired_total}/{len(step_list)*len(set_list)} jobs{suffix}]")


