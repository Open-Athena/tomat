@runs.command("status")
@click.argument("substr", required=False)
def runs_status(substr: str | None):
    """Show state/MFU/step/loss for one or all matching runs."""
    import wandb

    api = wandb.Api()
    rs = match_runs(api, substr)
    if not rs:
        err(f"no runs match {substr!r}")
        sys.exit(1)
    summaries = _fetch_summaries(rs, _STATUS_KEYS)
    summaries.sort(key=lambda d: d["created_at"], reverse=True)
    one_line = substr is None or len(summaries) > 1
    for d in summaries:
        if one_line:
            mfu = d.get("throughput/mfu")
            mfu_s = f"{mfu:5.2f}%" if isinstance(mfu, (int, float)) else "   -  "
            step = d["_step"]
            step_s = f"{step:>6}" if isinstance(step, int) else "     ?"
            runtime_h = (d["_runtime"] or 0) / 3600
            print(f"  [{d['state']:8s}] step={step_s} runtime={runtime_h:5.1f}h mfu={mfu_s}  {d['name']}")
        else:
            print(f"name:    {d['name']}")
            print(f"state:   {d['state']}")
            print(f"step:    {d['_step']}")
            print(f"runtime: {(d['_runtime'] or 0)/3600:.2f} hr")
            for k in _STATUS_KEYS:
                v = d.get(k)
                if v is not None:
                    print(f"  {k}: {v}")
            print(f"url:     {d['url']}")


def _scan_history_key(r, fk: str) -> list[tuple[int, float]]:
    return [
        (row["eval/mat_nmae/step"], row[fk])
        for row in r.scan_history(keys=["eval/mat_nmae/step", fk], page_size=200)
        if row.get("eval/mat_nmae/step") is not None and row.get(fk) is not None
    ]


def _per_mat_nemd(run_label: str, mat_set: str) -> dict[int, float]:
    """Pull nemd_mean per ckpt from GCS per-mat result JSONs.

    Returns mapping step → NEMD as a percentage (matching the wandb-side
    NMAE values, which are already in %).
    """
    import fsspec
    out: dict[int, float] = {}
    fs = fsspec.filesystem("gcs")
    base = f"marin-eu-west4/tomat/eval/results/{run_label}/{mat_set}"
    if not fs.exists(base):
        return out
    for path in fs.ls(base):
        name = path.rsplit("/", 1)[-1]
        if not (name.startswith("step-") and name.endswith(".json")):
            continue
        step = int(name[len("step-") : -len(".json")])
        try:
            with fs.open(path, "r") as f:
                d = json.load(f)
            v = d.get("nemd_mean")
            if v is not None:
                out[step] = float(v) * 100.0
        except Exception:
            pass
    return out


@runs.command("nmae")
@click.argument("substr")
@click.option("-s", "--sets", default="val_200,train_200", help="comma-sep mat-sets to show")
def runs_nmae(substr: str, sets: str):
    """Show mat-NMAE + (when available) mat-NEMD curve as a step × {set} table.

    NMAE comes from wandb (`eval/mat_nmae/...` logged by the eval watchdog).
    NEMD comes from per-mat result JSONs in GCS (eval_mat_nmae.py writes both
    when the eval is re-fired with the post-EMD-patch evaluator).
    """
    import wandb

    api = wandb.Api()
    r = require_one(match_runs(api, substr), substr)
    set_list = sets.split(",")
    keys = [f"{s}/{m}" for s in set_list for m in ("mean", "median", "p99")]
    data: dict[int, dict[str, float]] = {}
    with ThreadPoolExecutor(max_workers=min(8, len(keys))) as ex:
        futures = {ex.submit(_scan_history_key, r, f"eval/mat_nmae/{k}"): k for k in keys}
        for fut in as_completed(futures):
            k = futures[fut]
            for s, v in fut.result():
                data.setdefault(s, {})[k] = v

    nemd_by_set: dict[str, dict[int, float]] = {s: _per_mat_nemd(r.name, s) for s in set_list}

    if not data and not any(nemd_by_set.values()):
        err(f"no eval/mat_nmae/* history or NEMD JSONs for {r.name}")
        sys.exit(0)

    print(f"mat-NMAE+NEMD for {r.name} ({len(data)} step points; NEMD where avail)")
    header = "  step  "
    for s in set_list:
        header += f"  {s:>20} NMAE m/med/p99  NEMD"
    print(header)
    all_steps = sorted(set(data) | set().union(*[set(d) for d in nemd_by_set.values()]))
    for step in all_steps:
        d = data.get(step, {})
        line = f"  {step:>5}  "
        for s in set_list:
            ne = nemd_by_set.get(s, {}).get(step)
            ne_s = fmt(ne) if ne is not None else "  -  "
            line += f"  {fmt(d.get(s + '/mean'))}/{fmt(d.get(s + '/median'))}/{fmt(d.get(s + '/p99'))}  {ne_s}"
        print(line)


def _wandb_url(run_name: str) -> str:
    return f"{WANDB_BASE}/{WANDB_PROJECT}/runs/{run_name}"


def _iris_url(run_name: str) -> str:
    """Iris dashboard URL — path-encodes the leading / and any others."""
    from urllib.parse import quote
    return f"{IRIS_DASHBOARD}/#/job/{quote(f'/{IRIS_USER}/{run_name}', safe='')}"


def _latest_metric(r, key: str) -> tuple[int | None, float | None]:
    """Latest (step, value) for a given wandb metric key, or (None, None)."""
    pts = _scan_history_key(r, key)
    if not pts:
        return (None, None)
    return max(pts, key=lambda p: p[0])


