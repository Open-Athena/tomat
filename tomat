@runs.command("lifecycle-plot")
@click.argument("substr")
@click.option("-o", "--out", default=None,
              help="output PNG path (default: plots/lifecycle/<run>.png)")
@click.option("-u", "--upload", is_flag=True,
              help="also wandb.log({summary/lifecycle_overlay: Image(out)})")
@click.option("--show-loss/--no-show-loss", default=True)
@click.option("--show-nmae/--no-show-nmae", default=True)
def runs_lifecycle_plot(substr: str, out: str | None, upload: bool,
                        show_loss: bool, show_nmae: bool):
    """Plot loss + NMAE curves with vertical markers at every restart event.

    Reads `lifecycle/trainer_started` and `lifecycle/sigterm_received` from
    wandb history. Each `trainer_started` ≥ step 1 is a resume (the first
    is a fresh start). Output PNG is saved locally; pass --upload to also
    attach it to the wandb run as a Media artifact.
    """
    import matplotlib
    matplotlib.use("Agg")
    import matplotlib.pyplot as plt
    import wandb

    api = wandb.Api()
    r = require_one(match_runs(api, substr), substr)
    name = r.name

    # Pull history. wandb's history is keyed by `_step`; we ask for each
    # metric explicitly so it returns just the rows where that key is set.
    def hist(key: str) -> list[tuple[int, float]]:
        try:
            return [(int(row["_step"]), float(row[key]))
                    for row in r.scan_history(keys=["_step", key])
                    if row.get(key) is not None]
        except Exception:
            return []

    train_loss = hist("train/loss") if show_loss else []
    eval_loss = hist("eval/loss") if show_loss else []
    val_nmae = hist("eval/mat_nmae/val_200/mean") if show_nmae else []
    starts = hist("lifecycle/trainer_started")
    sigterms = hist("lifecycle/sigterm_received")

    fig, ax = plt.subplots(figsize=(11, 5.5))
    if train_loss:
        xs, ys = zip(*train_loss)
        ax.plot(xs, ys, lw=0.8, color="#1f77b4", label="train/loss", alpha=0.85)
    if eval_loss:
        xs, ys = zip(*eval_loss)
        ax.plot(xs, ys, lw=1.4, color="#d62728", marker="o", ms=3, label="eval/loss")
    ax.set_xlabel("step")
    ax.set_ylabel("loss")
    ax.set_yscale("log")
    ax.grid(alpha=0.3)

    if val_nmae:
        ax2 = ax.twinx()
        xs, ys = zip(*val_nmae)
        ax2.plot(xs, [y * 100 if y < 1 else y for y in ys],
                 lw=1.6, color="#2ca02c", marker="s", ms=4, label="val NMAE (%)")
        ax2.set_ylabel("val NMAE (%)", color="#2ca02c")
        ax2.tick_params(axis="y", labelcolor="#2ca02c")

    # Lifecycle overlay: dashed lines at every trainer_started step,
    # dotted lines at every sigterm. The first trainer_started is at
    # step 0 (fresh init) — skip it so we only see *resumes*.
    resume_steps = sorted({s for s, _ in starts if s > 0})
    sigterm_steps = sorted({s for s, _ in sigterms})
    for s in resume_steps:
        ax.axvline(s, color="#ff7f0e", ls="--", lw=0.9, alpha=0.7)
    for s in sigterm_steps:
        ax.axvline(s, color="#7f7f7f", ls=":", lw=0.7, alpha=0.5)

    ax.set_title(f"{name}  ·  {len(resume_steps)} resumes, "
                 f"{len(sigterm_steps)} sigterms")
    handles = [
        plt.Line2D([], [], color="#ff7f0e", ls="--", label=f"resume ({len(resume_steps)})"),
        plt.Line2D([], [], color="#7f7f7f", ls=":", label=f"sigterm ({len(sigterm_steps)})"),
    ]
    if train_loss: handles.insert(0, plt.Line2D([], [], color="#1f77b4", label="train/loss"))
    if eval_loss: handles.insert(1 if train_loss else 0, plt.Line2D([], [], color="#d62728", marker="o", ms=4, label="eval/loss"))
    if val_nmae: handles.append(plt.Line2D([], [], color="#2ca02c", marker="s", ms=4, label="val NMAE (%)"))
    ax.legend(handles=handles, loc="upper right", fontsize=9, framealpha=0.85)

    out_path = Path(out) if out else PROJECT_ROOT / "plots" / "lifecycle" / f"{name}.png"
    out_path.parent.mkdir(parents=True, exist_ok=True)
    fig.tight_layout()
    fig.savefig(out_path, dpi=130)
    plt.close(fig)
    print(f"wrote: {out_path}")
    print(f"  resumes: {len(resume_steps)}  sigterms: {len(sigterm_steps)}")
    if resume_steps:
        print(f"  resume steps: {resume_steps[:10]}{' …' if len(resume_steps) > 10 else ''}")

    if upload:
        run = wandb.init(
            entity=WANDB_PROJECT.split("/")[0],
            project=WANDB_PROJECT.split("/")[-1],
            id=name, resume="allow",
        )
        run.summary["summary/lifecycle_overlay"] = wandb.Image(str(out_path))
        run.finish()
        print(f"  uploaded to wandb run {name} as summary/lifecycle_overlay")


@cli.command("cost")
@click.option("-p", "--prefix", default="/ryan", help="iris job prefix to inspect")
@click.option("-f", "--filter", "filter_re", default="tomat|train-full|train-cont", help="regex on job name")
def cost(prefix: str, filter_re: str):
    """Estimate MSRP-equivalent compute spend across matching iris jobs.

    Sums chip-hours (TPU × duration) across visible parent jobs and prints
    preempt-rate and on-demand-rate equivalents. Public-rate, not actual.
    """
    # Parent jobs only — children inherit their parent's slice, would double-count.
    res = iris_run("list", "--prefix", prefix)
    out = strip_iris_log(res.stdout)
    pat = re.compile(filter_re)
    rows = []
    for line in out.split("\n"):
        if not line.strip() or "JOB ID" in line:
            continue
        jid = line.split()[0]
        if not jid.startswith("/") or jid.count("/") > 2:
            continue
        if not pat.search(jid):
            continue
        # Pull TPU + duration from the line — parsing is fragile, so summary
        # call would be more robust; defer until we build a json list option.
        m = re.search(r"v6e-(\d+)", line)
        chips = int(m.group(1)) if m else 0
        rows.append((jid, chips, line))
    if not rows:
        err(f"no matching jobs under {prefix!r}")
        sys.exit(0)

    print(f"# Jobs (prefix={prefix}, filter={filter_re}):")
    print(f"  found {len(rows)} parent jobs (chip-hour estimates require `iris job summary` per-job)")
    for jid, chips, _ in rows:
        print(f"  v6e-{chips:<3d}  {jid}")
    print()
    print(f"# Public TPU rates (v6e):")
