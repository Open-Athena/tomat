@cli.group("iris")
def iris_grp():
    """iris job mgmt — wraps `uv run iris --cluster=marin job ...`."""


def _parent_jids_matching(substr: str) -> list[str]:
    """Return parent (top-level) iris job IDs whose name contains SUBSTR."""
    matches = []
    for line in iris_list_lines():
        jid = line.split()[0]
        # Skip child tasks (extra path segments beyond /<user>/<job>)
        if jid.count("/") > 2:
            continue
        if substr in jid:
            matches.append(jid)
    return matches


def _walk_pools(node, parent_name=None):
    """Yield `{name, status, ready, reason, counts}` for every autoscaler pool."""
    if isinstance(node, dict):
        nm = node.get("name", parent_name)
        if "availability_status" in node:
            counts = node.get("slice_state_counts") or {}
            yield {
                "name": nm,
                "status": node.get("availability_status"),
                "ready": counts.get("ready", 0),
                "counts": counts,
                "reason": (node.get("availability_reason") or "").strip(),
            }
        for v in node.values():
            yield from _walk_pools(v, nm)
    elif isinstance(node, list):
        for v in node:
            yield from _walk_pools(v, parent_name)


@iris_grp.command("avail")
@click.option("-a", "--all", "show_all", is_flag=True, help="show every pool, including empty/`available` ones")
@click.option("-j", "--json", "as_json", is_flag=True, help="emit JSON instead of the human table")
@click.option("-t", "--tpu", default=None, help="substring filter on pool name (e.g. 'v5p', 'v6e', 'v4-')")
def iris_avail(show_all: bool, as_json: bool, tpu: str | None):
    """Show TPU pool availability via `iris rpc controller get-autoscaler-status`.

    Default view: pools with non-zero `ready` slices or a non-`available`
    status (quota_exceeded, backoff, requesting, cooldown). Use `-a` for the
    full dump (~150 pools).
    """
    cmd = ["uv", "run", "iris", "--cluster=marin", "rpc", "controller", "get-autoscaler-status"]
    r = subprocess.run(cmd, cwd=str(MARIN_DIR), capture_output=True, text=True, timeout=60)
    if r.returncode != 0:
        err(f"iris rpc failed: rc={r.returncode}\n{r.stderr}")
        sys.exit(r.returncode)
    out = strip_iris_log(r.stdout).strip()
    data = json.loads(out)
    pools = [p for p in _walk_pools(data) if p["name"]]
    if tpu:
        pools = [p for p in pools if tpu in p["name"]]
    pools.sort(key=lambda p: (p["status"] != "available", -p["ready"], p["name"]))

    def interesting(p):
        return show_all or p["ready"] > 0 or p["status"] != "available"

    pools = [p for p in pools if interesting(p)]
    if as_json:
        print(json.dumps(pools, indent=1, default=str))
        return
    if not pools:
        print("(no pools matched)")
        return
    print(f"{'STATUS':18s}  {'READY':>5s}  POOL")
    for p in pools:
        suffix = f"  {p['reason'][:50]}" if p["reason"] else ""
        print(f"{p['status']:18s}  {p['ready']:>5d}  {p['name']}{suffix}")


# iris job-state codes (from marin/lib/iris/docs/task-states.md).
_IRIS_JOB_STATE = {
    1: "PENDING",
    2: "BUILDING",
    3: "RUNNING",
    4: "SUCCEEDED",
    5: "FAILED",
    6: "KILLED",
    7: "WORKER_FAILED",
    8: "UNSCHEDULABLE",
}


def _iris_query_json(sql: str, timeout: int = 60) -> list[dict]:
    """Run a controller SQL query and parse the JSON result."""
    cmd = ["uv", "run", "iris", "--cluster=marin", "query", sql, "-f", "json"]
    r = subprocess.run(cmd, cwd=str(MARIN_DIR), capture_output=True, text=True, timeout=timeout)
    if r.returncode != 0:
        err(f"iris query failed: rc={r.returncode}\n{r.stderr[-500:]}")
        sys.exit(r.returncode)
    return json.loads(strip_iris_log(r.stdout).strip())


@iris_grp.command("sync")
@click.option("-b", "--bucket", default=R2_BUCKET, help="R2 bucket")
@click.option("-k", "--key", default="tomat/iris-state.json", help="R2 key")
@click.option("-l", "--limit", default=200, type=int, help="how many recent /ryan/* jobs to include")
@click.option("-d", "--dry-run", is_flag=True, help="print the JSON without uploading")
def iris_sync(bucket: str, key: str, limit: int, dry_run: bool):
    """Snapshot iris job state for our recent /ryan/* parent jobs → R2.

    Powers the iris-state column on tomat.oa.dev/runs. Manual invocation
    for now; consider `watch -n 60 tomat iris sync` while babysitting
    a fleet of training jobs, or cron from a small GCE box later.
    """
    sql = f"""
        SELECT
          j.job_id, j.name, j.state, j.error, j.exit_code,
          j.submitted_at_ms, j.started_at_ms, j.finished_at_ms,
          j.num_tasks,
          COALESCE(MAX(t.preemption_count), 0) AS preempts,
          COALESCE(MAX(t.failure_count), 0)    AS failures
        FROM jobs j
        LEFT JOIN tasks t ON t.job_id = j.job_id
        WHERE j.job_id LIKE '/ryan/%' AND (j.parent_job_id IS NULL OR j.parent_job_id = '')
        GROUP BY j.job_id
        ORDER BY j.submitted_at_ms DESC
        LIMIT {limit}
    """
    rows = _iris_query_json(sql)
    jobs: dict[str, dict] = {}
    for row in rows:
        state_code = int(row.get("state") or 0)
        jobs[row["job_id"]] = {
            "state": _IRIS_JOB_STATE.get(state_code, f"UNKNOWN_{state_code}"),
            "state_code": state_code,
            "preempts": int(row.get("preempts") or 0),
            "failures": int(row.get("failures") or 0),
            "error": row.get("error") or None,
            "exit_code": row.get("exit_code"),
            "submitted_at_ms": int(row["submitted_at_ms"]) if row.get("submitted_at_ms") else None,
            "started_at_ms": int(row["started_at_ms"]) if row.get("started_at_ms") else None,
            "finished_at_ms": int(row["finished_at_ms"]) if row.get("finished_at_ms") else None,
            "num_tasks": int(row.get("num_tasks") or 0),
        }
    payload = {
        "schema_version": 1,
        "synced_at": datetime.datetime.now(datetime.timezone.utc).isoformat(timespec="seconds"),
        "count": len(jobs),
        "jobs": jobs,
    }
    data = json.dumps(payload, indent=1).encode("utf-8")
    print(f"[iris sync] {len(jobs)} jobs → s3://{bucket}/{key} ({len(data)} bytes)")
    if dry_run:
        print(data.decode())
        return
    _r2_put_bytes(bucket, key, data, "application/json")
    print(f"[iris sync] {R2_ENDPOINT}/{bucket}/{key}")


@iris_grp.command("ls")
@click.option("-f", "--filter", "filter_re", default=None, help="extra regex filter on job line")
@click.option("-s", "--state", default=None, help="filter by state (running, failed, ...)")
@click.option("--all", "show_all", is_flag=True, help="include child task lines (default: parents only)")
def iris_ls(filter_re: str | None, state: str | None, show_all: bool):
    """List tomat-relevant /ryan/* iris jobs (parents only by default).

    Fans across `/ryan/{tomat,train,eval}` prefixes — iris requires --prefix
    to be a `/<user>/<jobname>` form, not a bare `/<user>`.
    """
    pat = re.compile(filter_re) if filter_re else None
    lines = iris_list_lines(state=state)
    print("JOB ID                                                                                              STATE      RESOURCES                          SUBMITTED                         REASON")
    for line in lines:
        jid = line.split()[0]
        if not show_all and jid.count("/") > 2:
            continue
        if pat and not pat.search(line):
            continue
        print(line)


@iris_grp.command("kill")
@click.argument("substr")
@click.option("-y", "--yes", is_flag=True, help="skip confirmation prompt")
def iris_kill(substr: str, yes: bool):
    """Kill iris jobs whose name matches SUBSTR (running ones only)."""
    matches = []
    for line in iris_list_lines(state="running"):
        jid = line.split()[0]
        if jid.count("/") > 2:
            continue
        if substr in jid:
            matches.append(jid)
    if not matches:
        err(f"no running parent jobs match {substr!r}")
        sys.exit(1)
    err(f"will kill {len(matches)} jobs:")
    for j in matches:
        err(f"  {j}")
    if not yes:
        if not click.confirm("proceed?", default=False):
            err("aborted")
            sys.exit(1)
    for j in matches:
        r = iris_run("kill", j)
        err(f"  killed {j}: rc={r.returncode}")


@iris_grp.command("logs")
@click.argument("substr")
@click.option("-n", "--max-lines", default=200, type=int)
@click.option("-l", "--level", default=None, help="warning|error|info|debug")
@click.option("--task", default=None, help="task index (e.g. 1); default = parent job")
def iris_logs(substr: str, max_lines: int, level: str | None, task: str | None):
    """Tail logs for a job (most recent N lines)."""
    matches = _parent_jids_matching(substr)
    if len(matches) != 1:
        err(f"expected 1 match for {substr!r}, got {len(matches)}: {matches}")
        sys.exit(1)
    jid = matches[0]
    if task is not None:
        jid = f"{jid}/{task}"
    args = ["logs", jid, "--tail", "--max-lines", str(max_lines)]
    if level:
        args += ["--level", level]
    r = iris_run(*args, capture=False, timeout=300)
    sys.exit(r.returncode)


@iris_grp.command("summary")
@click.argument("substr")
def iris_summary(substr: str):
    """Show per-task summary (state, exit, peak mem, error)."""
    matches = _parent_jids_matching(substr)
    if len(matches) != 1:
        err(f"expected 1 match for {substr!r}, got {len(matches)}: {matches}")
        sys.exit(1)
    r = iris_run("summary", matches[0], capture=False, timeout=120)
    sys.exit(r.returncode)


