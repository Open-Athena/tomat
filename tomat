@cli.group("iris")
def iris_grp():
    """iris job mgmt — wraps `uv run iris --cluster=marin job ...`."""


def _parent_jids_matching(substr: str) -> list[str]:
    """Return parent (top-level) iris job IDs whose name contains SUBSTR."""
    matches = []
    for line in iris_list_lines():
        jid = line.split()[0]
        # Skip child tasks (extra path segments beyond /<user>/<job>)
        if jid.count("/") > 2:
            continue
        if substr in jid:
            matches.append(jid)
    return matches


@iris_grp.command("ls")
@click.option("-f", "--filter", "filter_re", default=None, help="extra regex filter on job line")
@click.option("-s", "--state", default=None, help="filter by state (running, failed, ...)")
@click.option("--all", "show_all", is_flag=True, help="include child task lines (default: parents only)")
def iris_ls(filter_re: str | None, state: str | None, show_all: bool):
    """List tomat-relevant /ryan/* iris jobs (parents only by default).

    Fans across `/ryan/{tomat,train,eval}` prefixes — iris requires --prefix
    to be a `/<user>/<jobname>` form, not a bare `/<user>`.
    """
    pat = re.compile(filter_re) if filter_re else None
    lines = iris_list_lines(state=state)
    print("JOB ID                                                                                              STATE      RESOURCES                          SUBMITTED                         REASON")
    for line in lines:
        jid = line.split()[0]
        if not show_all and jid.count("/") > 2:
            continue
        if pat and not pat.search(line):
            continue
        print(line)


@iris_grp.command("kill")
@click.argument("substr")
@click.option("-y", "--yes", is_flag=True, help="skip confirmation prompt")
def iris_kill(substr: str, yes: bool):
    """Kill iris jobs whose name matches SUBSTR (running ones only)."""
    matches = []
    for line in iris_list_lines(state="running"):
        jid = line.split()[0]
        if jid.count("/") > 2:
            continue
        if substr in jid:
            matches.append(jid)
    if not matches:
        err(f"no running parent jobs match {substr!r}")
        sys.exit(1)
    err(f"will kill {len(matches)} jobs:")
    for j in matches:
        err(f"  {j}")
    if not yes:
        if not click.confirm("proceed?", default=False):
            err("aborted")
            sys.exit(1)
    for j in matches:
        r = iris_run("kill", j)
        err(f"  killed {j}: rc={r.returncode}")


@iris_grp.command("logs")
@click.argument("substr")
@click.option("-n", "--max-lines", default=200, type=int)
@click.option("-l", "--level", default=None, help="warning|error|info|debug")
@click.option("--task", default=None, help="task index (e.g. 1); default = parent job")
def iris_logs(substr: str, max_lines: int, level: str | None, task: str | None):
    """Tail logs for a job (most recent N lines)."""
    matches = _parent_jids_matching(substr)
    if len(matches) != 1:
        err(f"expected 1 match for {substr!r}, got {len(matches)}: {matches}")
        sys.exit(1)
    jid = matches[0]
    if task is not None:
        jid = f"{jid}/{task}"
    args = ["logs", jid, "--tail", "--max-lines", str(max_lines)]
    if level:
        args += ["--level", level]
    r = iris_run(*args, capture=False, timeout=300)
    sys.exit(r.returncode)


@iris_grp.command("summary")
@click.argument("substr")
def iris_summary(substr: str):
    """Show per-task summary (state, exit, peak mem, error)."""
    matches = _parent_jids_matching(substr)
    if len(matches) != 1:
        err(f"expected 1 match for {substr!r}, got {len(matches)}: {matches}")
        sys.exit(1)
    r = iris_run("summary", matches[0], capture=False, timeout=120)
    sys.exit(r.returncode)


