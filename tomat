@cli.group()
def runs():
    """Inspect wandb runs."""


def _summarize(r, keys: list[str]) -> dict:
    """Touch r.summary once (forces fetch) and pull the keys we need.

    Returns a flat dict including state, name, created_at, url, plus the
    requested summary keys. Designed to be called in a ThreadPoolExecutor.
    """
    s = r.summary
    out = {
        "name": r.name,
        "state": r.state,
        "created_at": r.created_at,
        "url": r.url,
        "_runtime": s.get("_runtime"),
        "_step": s.get("_step"),
    }
    for k in keys:
        out[k] = s.get(k)
    return out


def _fetch_summaries(rs, keys: list[str], max_workers: int = 16) -> list[dict]:
    """Fetch summaries for `rs` in parallel."""
    with ThreadPoolExecutor(max_workers=max_workers) as ex:
        futures = [ex.submit(_summarize, r, keys) for r in rs]
        return [f.result() for f in futures]


@runs.command("ls")
def runs_ls():
    """List all wandb runs in the project, newest first."""
    import wandb

    api = wandb.Api()
    rs = list(api.runs(WANDB_PROJECT))
    summaries = _fetch_summaries(rs, keys=[])
    summaries.sort(key=lambda d: d["created_at"], reverse=True)
    print(f"{len(summaries)} runs in {WANDB_PROJECT}:")
    for d in summaries:
        runtime_h = (d["_runtime"] or 0) / 3600
        step = d["_step"]
        step_s = f"{step:>6}" if isinstance(step, int) else "     ?"
        print(f"  [{d['state']:8s}] step={step_s} runtime={runtime_h:5.1f}h  {d['name']}")


_STATUS_KEYS = [
    "throughput/mfu",
    "throughput/p50_mfu",
    "throughput/duration",
    "throughput/tokens_per_second",
    "train/loss",
    "eval/loss",
]


@runs.command("status")
@click.argument("substr", required=False)
def runs_status(substr: str | None):
    """Show state/MFU/step/loss for one or all matching runs."""
    import wandb

    api = wandb.Api()
    rs = match_runs(api, substr)
    if not rs:
        err(f"no runs match {substr!r}")
        sys.exit(1)
    summaries = _fetch_summaries(rs, _STATUS_KEYS)
    summaries.sort(key=lambda d: d["created_at"], reverse=True)
    one_line = substr is None or len(summaries) > 1
    for d in summaries:
        if one_line:
            mfu = d.get("throughput/mfu")
            mfu_s = f"{mfu:5.2f}%" if isinstance(mfu, (int, float)) else "   -  "
            step = d["_step"]
            step_s = f"{step:>6}" if isinstance(step, int) else "     ?"
            runtime_h = (d["_runtime"] or 0) / 3600
            print(f"  [{d['state']:8s}] step={step_s} runtime={runtime_h:5.1f}h mfu={mfu_s}  {d['name']}")
        else:
            print(f"name:    {d['name']}")
            print(f"state:   {d['state']}")
            print(f"step:    {d['_step']}")
            print(f"runtime: {(d['_runtime'] or 0)/3600:.2f} hr")
            for k in _STATUS_KEYS:
                v = d.get(k)
                if v is not None:
                    print(f"  {k}: {v}")
            print(f"url:     {d['url']}")


def _scan_history_key(r, fk: str) -> list[tuple[int, float]]:
    return [
        (row["eval/mat_nmae/step"], row[fk])
        for row in r.scan_history(keys=["eval/mat_nmae/step", fk], page_size=200)
        if row.get("eval/mat_nmae/step") is not None and row.get(fk) is not None
    ]


def _per_mat_nemd(run_label: str, mat_set: str) -> dict[int, float]:
    """Pull nemd_mean per ckpt from GCS per-mat result JSONs.

    Returns mapping step → NEMD as a percentage (matching the wandb-side
    NMAE values, which are already in %).
    """
    import fsspec
    out: dict[int, float] = {}
    fs = fsspec.filesystem("gcs")
    base = f"marin-eu-west4/tomat/eval/results/{run_label}/{mat_set}"
    if not fs.exists(base):
        return out
    for path in fs.ls(base):
        name = path.rsplit("/", 1)[-1]
        if not (name.startswith("step-") and name.endswith(".json")):
            continue
        step = int(name[len("step-") : -len(".json")])
        try:
            with fs.open(path, "r") as f:
                d = json.load(f)
            v = d.get("nemd_mean")
            if v is not None:
                out[step] = float(v) * 100.0
        except Exception:
            pass
    return out


@runs.command("nmae")
@click.argument("substr")
@click.option("-s", "--sets", default="val_200,train_200", help="comma-sep mat-sets to show")
def runs_nmae(substr: str, sets: str):
    """Show mat-NMAE + (when available) mat-NEMD curve as a step × {set} table.

    NMAE comes from wandb (`eval/mat_nmae/...` logged by the eval watchdog).
    NEMD comes from per-mat result JSONs in GCS (eval_mat_nmae.py writes both
    when the eval is re-fired with the post-EMD-patch evaluator).
    """
    import wandb

    api = wandb.Api()
    r = require_one(match_runs(api, substr), substr)
    set_list = sets.split(",")
    keys = [f"{s}/{m}" for s in set_list for m in ("mean", "median", "p99")]
    data: dict[int, dict[str, float]] = {}
    with ThreadPoolExecutor(max_workers=min(8, len(keys))) as ex:
        futures = {ex.submit(_scan_history_key, r, f"eval/mat_nmae/{k}"): k for k in keys}
        for fut in as_completed(futures):
            k = futures[fut]
            for s, v in fut.result():
                data.setdefault(s, {})[k] = v

    nemd_by_set: dict[str, dict[int, float]] = {s: _per_mat_nemd(r.name, s) for s in set_list}

    if not data and not any(nemd_by_set.values()):
        err(f"no eval/mat_nmae/* history or NEMD JSONs for {r.name}")
        sys.exit(0)

    print(f"mat-NMAE+NEMD for {r.name} ({len(data)} step points; NEMD where avail)")
    header = "  step  "
    for s in set_list:
        header += f"  {s:>20} NMAE m/med/p99  NEMD"
    print(header)
    all_steps = sorted(set(data) | set().union(*[set(d) for d in nemd_by_set.values()]))
    for step in all_steps:
        d = data.get(step, {})
        line = f"  {step:>5}  "
        for s in set_list:
            ne = nemd_by_set.get(s, {}).get(step)
            ne_s = fmt(ne) if ne is not None else "  -  "
            line += f"  {fmt(d.get(s + '/mean'))}/{fmt(d.get(s + '/median'))}/{fmt(d.get(s + '/p99'))}  {ne_s}"
        print(line)


def _wandb_url(run_name: str) -> str:
    return f"{WANDB_BASE}/{WANDB_PROJECT}/runs/{run_name}"


def _iris_url(run_name: str) -> str:
    """Iris dashboard URL — path-encodes the leading / and any others."""
    from urllib.parse import quote
    return f"{IRIS_DASHBOARD}/#/job/{quote(f'/{IRIS_USER}/{run_name}', safe='')}"


def _latest_metric(r, key: str) -> tuple[int | None, float | None]:
    """Latest (step, value) for a given wandb metric key, or (None, None)."""
    pts = _scan_history_key(r, key)
    if not pts:
        return (None, None)
    return max(pts, key=lambda p: p[0])


@runs.command("links")
@click.argument("substr", required=False)
@click.option("-n", "--limit", type=int, default=20, help="max runs to show (most recent first)")
@click.option("--md/--no-md", default=True, help="markdown table (default; --no-md for plain text)")
def runs_links(substr: str | None, limit: int, md: bool):
    """Markdown table of recent runs with state, step, mfu, val NMAE/NEMD,
    and direct links to wandb + iris dashboard (slack-paste-ready)."""
    import wandb

    api = wandb.Api()
    rs = match_runs(api, substr)
    summaries = _fetch_summaries(rs, _STATUS_KEYS)
    summaries.sort(key=lambda d: d["created_at"], reverse=True)
    summaries = summaries[:limit]

    # Look up latest val NMAE + NEMD from wandb history per run.
    name_to_run = {r.name: r for r in rs}
    rows = []
    for d in summaries:
        name = d["name"]
        r = name_to_run.get(name)
        nmae_step, nmae = _latest_metric(r, "eval/mat_nmae/val_200/mean") if r else (None, None)
        nemd_step, nemd = _latest_metric(r, "eval/mat_nemd/val_200/mean") if r else (None, None)
        mfu = d.get("throughput/mfu")
        rows.append({
            "name": name,
            "state": d["state"],
            "step": d["_step"] if isinstance(d["_step"], int) else None,
            "runtime_h": (d["_runtime"] or 0) / 3600,
            "mfu": mfu if isinstance(mfu, (int, float)) else None,
            "nmae": nmae,
            "nmae_step": nmae_step,
            "nemd": nemd,
            "nemd_step": nemd_step,
        })

    if md:
        # Slack renders markdown tables; keep cells terse.
        print("| run | state | step | runtime | MFU | val NMAE | val NEMD | wandb | iris |")
        print("|---|---|---|---|---|---|---|---|---|")
        for r in rows:
            step_s = f"{r['step']}" if r["step"] is not None else "-"
            rt_s = f"{r['runtime_h']:.1f}h"
            mfu_s = f"{r['mfu']:.1f}%" if r["mfu"] is not None else "-"
            # Use ` @ ` (with spaces) so GitHub doesn't render "@<step>" as a user mention.
            nmae_s = f"{r['nmae']:.2f}% @ {r['nmae_step']}" if r["nmae"] is not None else "-"
            nemd_s = f"{r['nemd']:.2f}% @ {r['nemd_step']}" if r["nemd"] is not None else "-"
            wb = f"[wb]({_wandb_url(r['name'])})"
            ir = f"[iris]({_iris_url(r['name'])})"
            print(f"| `{r['name']}` | {r['state']} | {step_s} | {rt_s} | {mfu_s} | {nmae_s} | {nemd_s} | {wb} | {ir} |")
    else:
        for r in rows:
            print(f"name:    {r['name']}")
            print(f"  state:   {r['state']}")
            print(f"  step:    {r['step']}    runtime: {r['runtime_h']:.2f}h    mfu: {r['mfu']}")
            if r["nmae"] is not None:
                print(f"  val NMAE: {r['nmae']:.3f}% @ step {r['nmae_step']}")
            if r["nemd"] is not None:
                print(f"  val NEMD: {r['nemd']:.3f}% @ step {r['nemd_step']}")
            print(f"  wandb:   {_wandb_url(r['name'])}")
            print(f"  iris:    {_iris_url(r['name'])}")
            print()


