@click.option("--max-retries", default=20, show_default=True, type=int, help="iris --max-retries (failure budget; iris default is 0, which classifies JAX-distributed leader-preempt cascades as fatal failures. 20 buys us ~20 sibling-cascade survivals before terminal.)")
@click.option("-e", "--env", "extra_env", multiple=True, help="extra env var KEY=VAL (repeatable)")
@click.option("--shuffle-window-blocks", type=int, default=0, help="TOMAT_SHUFFLE_WINDOW_BLOCKS; 0 = no shuffle (default), >0 = BlockShuffle window radius")
@click.option("--shuffle-io-block-size", type=int, default=0, help="TOMAT_SHUFFLE_IO_BLOCK_SIZE; 0 = auto from meta (M)")
@click.option("--share-cache/--no-share-cache", default=True, help="Trainer reads the mirrored cache at `<bucket>/cache/<data_label>/` (default on). With TOMAT_SHARE_CACHE=1, the trainer detects its actual GCE zone at startup and picks the local-region mirror — drop `--zone` to let iris park the slice wherever has capacity. `--no-share-cache` falls back to per-run rebuild under the canonical bucket.")
@click.option("--watch-preempts/--no-watch-preempts", default=True, help="auto-fire `tomat preempts watch <LABEL>` in the background after launch (default on)")
@click.option("--pyspy/--no-pyspy", default=False, help="TOMAT_PYSPY=1 → trainer daemon-dumps py-spy stacks to GCS every TOMAT_PYSPY_INTERVAL s (default 60). Use for diagnosing host-side stalls (the 65s/step v5p issue).")
@click.option("--pyspy-interval", default=60, type=int, help="TOMAT_PYSPY_INTERVAL seconds between py-spy dumps (default 60).")
@click.option("--pyspy-record-seconds", default=0, type=int, help="TOMAT_PYSPY_RECORD_SECONDS > 0 switches from `py-spy dump` (text) to `py-spy record` (flame-graph SVG) of that length per cycle.")
@click.option("-f", "--force", is_flag=True, help="allow from-scratch overwrite of existing results dir")
@click.option("-d", "--dry-run", is_flag=True, help="print iris cmd without firing")
@click.argument("label")
def train(
    label: str,
    resume_mode: bool,
    data_label: str,
    model: str,
    tpu: str,
    zone: str | None,
    region: str | None,
    steps: int,
    batch_size: int,
    seed: int,
    lmq_path: str | None,
    lr: float,
    lr_schedule: str,
    warmup: float,
    cooldown: float | None,
    val_seqs: int,
    steps_per_eval: int | None,
    grad_ckpt: bool,
    profile: bool,
    density_loss: str,
    density_only: bool,
    cpu: int,
    memory: str,
    max_retries: int,
    extra_env: tuple[str, ...],
    shuffle_window_blocks: int,
    shuffle_io_block_size: int,
    share_cache: bool,
    watch_preempts: bool,
    pyspy: bool,
    pyspy_interval: int,
    pyspy_record_seconds: int,
    force: bool,
    dry_run: bool,
):
    """Launch (or resume) a tomat training run.

    Modes:
      from-scratch (default)   new run with LABEL; errors if results dir exists
      --resume / -r            continue existing run (same LABEL); errors if
                               no checkpoints found. Native Levanter auto-
                               discovery loads the latest ckpt + optimizer
                               state intact.

    Warm-start (model-only load, fresh optimizer) is NOT a supported mode —
    it caused the 1B cont-from-4711 spike. If you want it back, add it as
    an explicit flag with safer LR defaults.
    """
    # Pick a region-local bucket to avoid cross-region transfer budget
    # blowups (rigging's MARIN_MIRROR_BUDGET_GB=10 default trips at the
    # first ckpt save for a v5p job writing back to marin-eu-west4).
    # v5p lives in us-central1/us-east5; v6e-preemptible-16 currently in
    # us-east1; everything else stays on eu-west4.
    if tpu.startswith("v5p"):
        bucket = "gs://marin-us-central1/tomat"
    elif tpu.startswith("v5e") or tpu.startswith("v6e"):
        bucket = "gs://marin-eu-west4/tomat"
    else:
        bucket = "gs://marin-eu-west4/tomat"  # default
    if bucket != GCS_BUCKET:
        print(f"[tomat train] bucket: {bucket} (tpu={tpu}; default would have been {GCS_BUCKET})")

    latest = _latest_ckpt_step(label, bucket=bucket)
    if resume_mode:
        if latest is None:
            err(f"--resume {label}: no step-* ckpts under "
                f"{bucket}/results/{label}/checkpoints/{label}/")
            sys.exit(1)
        print(f"[tomat train] resume mode: latest ckpt step-{latest} → "
              f"continuing to step {steps}")
    else:
        if latest is not None and not force:
            err(f"results dir for {label!r} already has step-{latest} ckpt at {bucket}; "
                f"use --resume to continue, or --force to overwrite")
            sys.exit(1)

    wandb_key = os.environ.get("WANDB_API_KEY", "<WANDB_API_KEY>")
    if not dry_run and wandb_key == "<WANDB_API_KEY>":
        err("WANDB_API_KEY not set in env")
        sys.exit(1)

    # Bucket-relative LMQ codec path: assume the codec was mirrored into
    # the same prefix under the target bucket (e.g. via
    # `gsutil cp gs://marin-eu-west4/tomat/codecs/* gs://marin-us-central1/tomat/codecs/`).
    default_lmq_path = f"{bucket}/codecs/lmq-v2-16k.npz"
    env_vars: list[tuple[str, str]] = [
        ("WANDB_API_KEY", wandb_key),
        ("TOMAT_BUCKET", bucket),
        ("TOMAT_LABEL", data_label),
        ("TOMAT_RESULTS_LABEL", label),
        ("TOMAT_MODEL", model),
        ("TOMAT_STEPS", str(steps)),
        ("TOMAT_BATCH_SIZE", str(batch_size)),
        ("TOMAT_SEED", str(seed)),
        ("TOMAT_LMQ_PATH", lmq_path or default_lmq_path),
        ("TOMAT_DENSITY_LOSS_TYPE", density_loss),
        ("TOMAT_DENSITY_ONLY_LOSS", "1" if density_only else "0"),
        ("TOMAT_LR", str(lr)),
        ("TOMAT_LR_SCHEDULE", lr_schedule),
        ("TOMAT_WARMUP", str(warmup)),
        ("TOMAT_VAL_SEQS", str(val_seqs)),
        ("TOMAT_PROFILE", "1" if profile else "0"),
    ]
    if cooldown is not None:
        env_vars.append(("TOMAT_COOLDOWN", str(cooldown)))
    if steps_per_eval is not None:
        env_vars.append(("TOMAT_STEPS_PER_EVAL", str(steps_per_eval)))
    env_vars.append(("TOMAT_GRADIENT_CHECKPOINTING", "1" if grad_ckpt else "0"))
    if shuffle_window_blocks > 0:
        env_vars.append(("TOMAT_SHUFFLE_WINDOW_BLOCKS", str(shuffle_window_blocks)))
        if shuffle_io_block_size > 0:
            env_vars.append(("TOMAT_SHUFFLE_IO_BLOCK_SIZE", str(shuffle_io_block_size)))
    if share_cache:
        # Trainer detects its actual GCE region at startup and picks the
        # matching mirror — no submit-time bucket pinning needed.
        env_vars.append(("TOMAT_SHARE_CACHE", "1"))
    if pyspy:
        env_vars.append(("TOMAT_PYSPY", "1"))
        env_vars.append(("TOMAT_PYSPY_INTERVAL", str(pyspy_interval)))
        if pyspy_record_seconds > 0:
            env_vars.append(("TOMAT_PYSPY_RECORD_SECONDS", str(pyspy_record_seconds)))
    for kv in extra_env:
        if "=" not in kv:
            err(f"--env {kv!r}: expected KEY=VAL")
            sys.exit(1)
        k, v = kv.split("=", 1)
        env_vars.append((k, v))

    cmd = [
        "uv", "run", "iris", "--cluster=marin", "job", "run",
        "--tpu", tpu, "--enable-extra-resources",
        "--cpu", str(cpu), "--memory", memory,
        "--max-retries", str(max_retries),
    ]
    for z in (zone or "").split(","):
        if z := z.strip():
            cmd += ["--zone", z]
    for r in (region or "").split(","):
        if r := r.strip():
            cmd += ["--region", r]
    for k, v in env_vars:
        cmd += ["--env-vars", k, v]
    cmd += [
        "--no-wait", "--no-terminate-on-exit",
        "--job-name", label,
        "--", "python", "train_tomat_tpu.py",
    ]

    if dry_run:
        pretty = " ".join(
            "'<WANDB_API_KEY>'" if a == wandb_key else a for a in cmd
        )
        print(f"# {label} ({'resume' if resume_mode else 'from-scratch'})")
        print(f"  cd {MARIN_DIR}")
        print(f"  {pretty}")
        return

    r = subprocess.run(cmd, cwd=str(MARIN_DIR), capture_output=True, text=True)
    if r.returncode != 0:
        err(f"[FAIL launch {label}] rc={r.returncode}\n{r.stderr[-1000:]}")
        sys.exit(r.returncode)
    print(f"[launched {label} on {tpu}, {steps} steps"
          f"{f' (resume from step-{latest})' if resume_mode else ''}]")
    print(f"  wandb: https://wandb.ai/{WANDB_PROJECT}/runs/{label}")

    if watch_preempts:
        # Background-fire `tomat preempts watch <label>` so the wandb run
        # carries cluster/preemptions + cluster/preempts_delta from the
        # start. Per-run log file lives at tmp/preempts-<label>.log.
        Path("tmp").mkdir(exist_ok=True)
        watch_log = Path("tmp") / f"preempts-{label}.log"
        watch_proc = subprocess.Popen(
            [str(Path(__file__).resolve()), "preempts", "watch", label],
            stdout=open(watch_log, "ab"),
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )
        print(f"[preempts watch pid={watch_proc.pid} log={watch_log}]")


