def _parse_preempts(summary_text: str) -> tuple[int, int] | None:
    """Parse preemption + failure counts from `iris job summary` output.

    Looks for a line like: `State: running  exit=0  failures=N  preemptions=M`
    Returns (preemptions, failures) or None if not found.
    """
    m = re.search(r"failures=(\d+)\s+preemptions=(\d+)", summary_text)
    if not m:
        return None
    return int(m.group(2)), int(m.group(1))


@cli.group()
def preempts():
    """Preempt-count tracking: pull from iris, post to wandb."""


@preempts.command("show")
@click.argument("substr")
def preempts_show(substr: str):
    """Show current preempt + failure counts for a job."""
    matches = _parent_jids_matching(substr)
    if len(matches) != 1:
        err(f"expected 1 match for {substr!r}, got {len(matches)}: {matches}")
        sys.exit(1)
    res = iris_run("summary", matches[0])
    out = strip_iris_log(res.stdout)
    parsed = _parse_preempts(out)
    if parsed is None:
        err("couldn't parse preempt/failure counts from summary")
        print(out)
        sys.exit(1)
    p, f = parsed
    print(f"job: {matches[0]}")
    print(f"  preemptions: {p}")
    print(f"  failures: {f}")


@preempts.command("watch")
@click.argument("substr")
@click.option("-i", "--interval", default=60, type=int, help="poll interval (sec)")
@click.option("--max-iters", default=0, type=int, help="stop after N iters (0 = run forever)")
def preempts_watch(substr: str, interval: int, max_iters: int):
    """Poll iris every INTERVAL sec and post preempt/failure counts to wandb.

    Logged to the matching wandb run under:
      cluster/preemptions   — cumulative preempt count
      cluster/failures      — cumulative task failure count
      cluster/preempts_per_hour  — derived rate over the watch window

    Designed to run as a background process, e.g.:
      ./tomat preempts watch cont-from-4711 > tmp/preempts.log 2>&1 &

    Uses a custom 'cluster/elapsed_min' as the wandb step axis so values
    can be back-filled into a long-running training run without colliding
    with its main step counter.
    """
    import time
    import wandb

    iris_matches = _parent_jids_matching(substr)
    if len(iris_matches) != 1:
        err(f"expected 1 iris match for {substr!r}, got {len(iris_matches)}: {iris_matches}")
        sys.exit(1)
    jid = iris_matches[0]
    # Run name == iris job name (without /ryan/ prefix).
    run_name = jid.split("/", 2)[-1]

    api = wandb.Api()
    wb_runs = match_runs(api, run_name)
    if not wb_runs:
        err(f"no wandb run named {run_name!r} (the job may not have started logging yet)")
        err("will retry every iter until it appears")
    else:
        err(f"watching iris={jid}, wandb={wb_runs[0].url}")

    # Use wandb's resumed run init to write into the existing run.
    run = wandb.init(
        project=WANDB_PROJECT.split("/")[-1],
        entity=WANDB_PROJECT.split("/")[0],
        id=run_name,
        resume="allow",
        # Don't sync the implicit step; we're appending out-of-band metrics.
    )
    run.define_metric("cluster/elapsed_min")
    run.define_metric("cluster/*", step_metric="cluster/elapsed_min")

    t_start = time.time()
    last_p = -1
    last_f = -1
    n = 0
    while True:
        elapsed_min = (time.time() - t_start) / 60.0
        res = iris_run("summary", jid)
        out = strip_iris_log(res.stdout)
        parsed = _parse_preempts(out)
        if parsed is not None:
            p, f = parsed
            rate = (p / (elapsed_min / 60.0)) if elapsed_min > 0.5 else 0.0
            # `*_delta` are per-poll increments — non-zero entries on the
            # wandb time-series mark *when* preempt/failure events landed,
            # which the cumulative count obscures.
            dp = max(0, p - last_p) if last_p >= 0 else 0
            df = max(0, f - last_f) if last_f >= 0 else 0
            run.log(
                {
                    "cluster/preemptions": p,
                    "cluster/failures": f,
                    "cluster/preempts_delta": dp,
                    "cluster/failures_delta": df,
                    "cluster/preempts_per_hour": rate,
                    "cluster/elapsed_min": elapsed_min,
                }
            )
            # Surface cumulative counters to the run's summary so the runs
            # table (and `tomat runs status`) can see them without a chart.
            run.summary["cluster/preempts_total"] = p
            run.summary["cluster/failures_total"] = f
            if p != last_p or f != last_f:
                err(f"[{elapsed_min:5.1f} min] preempts={p} (+{dp}) "
                    f"failures={f} (+{df}) rate={rate:.2f}/hr")
                last_p, last_f = p, f
        else:
            err(f"[{elapsed_min:5.1f} min] couldn't parse summary; retrying")

        n += 1
        if max_iters and n >= max_iters:
            break
        time.sleep(interval)

    run.finish()


