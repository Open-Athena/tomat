            print(f"  wandb:   {_wandb_url(r['name'])}")
            print(f"  iris:    {_iris_url(r['name'])}")
            print()


def _run_parquet_arrow_schema():
    """Lazy-build the per-run history parquet schema (pyarrow). Mirrors
    `_RUN_PARQUET_KEYS` order. `_step` is non-null; everything else nullable."""
    import pyarrow as pa
    return pa.schema([
        ("_step",                            pa.int64()),
        ("_timestamp",                       pa.float64()),
        ("_runtime",                         pa.float64()),
        ("global_step",                      pa.int64()),
        ("train/loss",                       pa.float32()),
        ("eval/loss",                        pa.float32()),
        ("throughput/mfu",                   pa.float32()),
        ("throughput/tokens_per_second",     pa.float32()),
        ("throughput/duration",              pa.float32()),
        ("eval/mat_nmae/val_200/mean",       pa.float32()),
        ("eval/mat_nmae/val_200/median",     pa.float32()),
        ("eval/mat_nmae/val_200/p99",        pa.float32()),
        ("eval/mat_nemd/val_200/mean",       pa.float32()),
        ("eval/mat_nemd/val_200/median",     pa.float32()),
        ("eval/mat_nemd/val_200/p99",        pa.float32()),
        ("lifecycle/trainer_started",        pa.int8()),
        ("lifecycle/sigterm_received",       pa.int8()),
        ("lifecycle/trainer_finished",       pa.int8()),
        ("cluster/preemptions",              pa.int32()),
        ("cluster/failures",                 pa.int32()),
        ("cluster/preempts_delta",           pa.int32()),
        ("cluster/failures_delta",           pa.int32()),
        ("cluster/preempts_per_hour",        pa.float32()),
        ("cluster/elapsed_min",              pa.float32()),
    ])


def _r2_put_bytes(bucket: str, key: str, data: bytes, content_type: str):
    """Upload `data` to `s3://bucket/key` on OA's R2 via `aws s3 cp` (cfo profile).

    Shell-out matches the existing `scripts/publish_mpdb.py` pattern;
    avoids adding boto3 as a project dep just for this."""
    import tempfile
    with tempfile.NamedTemporaryFile(delete=False) as f:
        f.write(data)
        path = f.name
    try:
        r = subprocess.run(
            ["aws", "--profile", "cfo", "--endpoint-url", R2_ENDPOINT,
             "s3", "cp", path, f"s3://{bucket}/{key}",
             "--content-type", content_type,
             "--cache-control", "public, max-age=60"],
            capture_output=True, text=True, timeout=120,
        )
        if r.returncode != 0:
            err(f"[sync] aws s3 cp failed: rc={r.returncode}")
            err(r.stderr[-1000:])
            sys.exit(2)
    finally:
        Path(path).unlink(missing_ok=True)


@runs.command("sync")
@click.option("-b", "--bucket", default=R2_BUCKET, help="R2 bucket")
@click.option("-p", "--prefix", default=R2_RUNS_PREFIX,
              help="R2 key prefix (run id appended)")
@click.option("-n", "--dry-run", is_flag=True,
              help="fetch + assemble, but skip the upload")
@click.option("-o", "--out-dir", default=None,
              help="if set, also write a local copy of the parquet + manifest")
@click.argument("substr")
def runs_sync(substr: str, bucket: str, prefix: str, dry_run: bool, out_dir: str | None):
    """Pull a wandb run's history → parquet → OA's R2.

    Writes `s3://<bucket>/<prefix>/<run_name>/{raw.parquet,manifest.json}`.
    Phase-A scaffolding for the `tomat.oa.dev/runs` dashboard
    (see `specs/23-runs-dashboard.md`).

    `scan_history(keys=…)` returns rows where ALL keys are set, not
    at-least-one — so we scan unfiltered and project to
    `_RUN_PARQUET_KEYS` in post.
    """
    import io
    import json
    from datetime import datetime, timezone
    import wandb
    import pyarrow as pa
    import pyarrow.parquet as pq

    api = wandb.Api()
    r = require_one(match_runs(api, substr), substr)
    err(f"[sync] run: {r.name} (state={r.state}, project={r.project})")

    keep = set(_RUN_PARQUET_KEYS)
    rows = []
    for row in r.scan_history():
        projected = {k: v for k, v in row.items() if k in keep}
        if any(k for k in projected if not k.startswith("_")):
            rows.append(projected)
    err(f"[sync] pulled {len(rows)} history rows")

    schema = _run_parquet_arrow_schema()
    if rows:
        rows = sorted(rows, key=lambda d: d.get("_step") or -1)
        cols = {f.name: [d.get(f.name) for d in rows] for f in schema}
        table = pa.Table.from_arrays(
            [pa.array(cols[f.name], type=f.type) for f in schema], schema=schema,
        )
    else:
        table = pa.Table.from_pylist([], schema=schema)

    buf = io.BytesIO()
    # snappy not zstd: hyparquet's default build doesn't include the ZSTD
    # codec, and these files are < 1 MB so the compression-ratio diff is moot.
    pq.write_table(table, buf, compression="snappy", row_group_size=10**7)
    parquet_bytes = buf.getvalue()
    err(f"[sync] parquet: {len(parquet_bytes)/1e6:.2f} MB"
        f" ({table.num_rows} rows × {len(schema)} cols)")

    step_col = table.column("_step")
    ts_col = table.column("_timestamp")
    summary = dict(r.summary)
    manifest = {
        "schema_version": _RUN_PARQUET_SCHEMA_VERSION,
        "synced_at": datetime.now(timezone.utc).isoformat(timespec="seconds"),
        "run": {
            "id": r.id, "name": r.name,
            "project": r.project, "entity": r.entity,
            "state": r.state, "url": r.url, "created_at": r.created_at,
            "tags": list(r.tags or []), "group": r.group,
            "config": dict(r.config),
        },
        "summary": {k: v for k, v in summary.items()
                    if isinstance(v, (int, float, bool, str)) or v is None},
        "history": {
            "rows": table.num_rows,
            "step_min": int(step_col[0].as_py()) if table.num_rows else None,
            "step_max": int(step_col[-1].as_py()) if table.num_rows else None,
            "ts_min": float(ts_col[0].as_py()) if table.num_rows and ts_col[0].is_valid else None,
            "ts_max": float(ts_col[-1].as_py()) if table.num_rows and ts_col[-1].is_valid else None,
        },
    }
    manifest_bytes = json.dumps(manifest, indent=2).encode()
    err(f"[sync] manifest: {len(manifest_bytes)} bytes,"
        f" step range [{manifest['history']['step_min']}, {manifest['history']['step_max']}]")

    if out_dir:
        d = Path(out_dir) / r.name
        d.mkdir(parents=True, exist_ok=True)
        (d / "raw.parquet").write_bytes(parquet_bytes)
        (d / "manifest.json").write_bytes(manifest_bytes)
        err(f"[sync] wrote local copy: {d}/")

    if dry_run:
        err("[sync] dry-run — skipping R2 upload")
        return

    parquet_key = f"{prefix}/{r.name}/raw.parquet"
    manifest_key = f"{prefix}/{r.name}/manifest.json"
    _r2_put_bytes(bucket, parquet_key, parquet_bytes, "application/octet-stream")
    _r2_put_bytes(bucket, manifest_key, manifest_bytes, "application/json")
    err(f"[sync] uploaded to s3://{bucket}/{prefix}/{r.name}/{{raw.parquet,manifest.json}}")
    print(f"{R2_ENDPOINT}/{bucket}/{parquet_key}")


@runs.command("wallclock-plot")
@click.argument("substr")
@click.option("-o", "--out", default=None,
              help="output PNG path (default: plots/wallclock/<run>.png)")
@click.option("-u", "--upload", is_flag=True,
              help="also wandb.log({summary/wallclock_overlay: Image(out)})")
def runs_wallclock_plot(substr: str, out: str | None, upload: bool):
    """Plot step count + loss over WALLCLOCK time, with markers at every
    sigterm / restart event.

    Useful for visualizing the cost of preempts: gaps in the step curve =
    time spent re-initing rather than training. Sigterm markers (gray) +
    cluster preempt-count steps (purple) show when each iris-side event
    landed in real time, regardless of where on the global step axis they
    fell.
    """
    import matplotlib
    matplotlib.use("Agg")
    import matplotlib.dates as mdates
    import matplotlib.pyplot as plt
    from datetime import datetime, timezone
    import wandb

    api = wandb.Api()
    r = require_one(match_runs(api, substr), substr)
    name = r.name

    def hist(key: str) -> list[tuple[float, float]]:
        """Return [(unix_ts, value)] pairs for KEY. wandb's `_timestamp`
        is absolute Unix epoch seconds (not relative to run start)."""
        out: list[tuple[float, float]] = []
        try:
            for row in r.scan_history(keys=["_timestamp", "_step", key]):
                v = row.get(key)
                if v is None:
                    continue
                ts = row.get("_timestamp")
                if ts is None:
                    continue
                out.append((float(ts), float(v)))
        except Exception:
            pass
        return out

    step_pts = hist("_step")        # treat _step itself as a "metric" — gives (ts, step)
    train_loss = hist("train/loss")
    preempts_total = hist("cluster/preemptions")
    starts = hist("lifecycle/trainer_started")
    sigterms = hist("lifecycle/sigterm_received")

    def to_dt(ts: float):
        return datetime.fromtimestamp(ts, tz=timezone.utc)

    fig, ax = plt.subplots(figsize=(12, 5.5))

    if step_pts:
        xs = [to_dt(t) for t, _ in step_pts]
        ys = [s for _, s in step_pts]
        ax.plot(xs, ys, lw=1.4, color="#1f77b4", label="step")
        ax.set_ylabel("step", color="#1f77b4")
        ax.tick_params(axis="y", labelcolor="#1f77b4")

    if train_loss:
        ax2 = ax.twinx()
        xs = [to_dt(t) for t, _ in train_loss]
        ys = [v for _, v in train_loss]
        ax2.plot(xs, ys, lw=0.6, color="#d62728", alpha=0.4, label="train/loss")
        ax2.set_ylabel("train/loss", color="#d62728")
        ax2.tick_params(axis="y", labelcolor="#d62728")
        ax2.set_yscale("log")

    # Vertical markers at sigterm + trainer_started events.
    for ts, _ in sigterms:
        ax.axvline(to_dt(ts), color="#7f7f7f", ls=":", lw=0.7, alpha=0.5)
    for ts, _ in starts:
        ax.axvline(to_dt(ts), color="#ff7f0e", ls="--", lw=0.9, alpha=0.7)
    # Mark each new value of cluster/preemptions (jumps in iris's count).
    last_p: float | None = None
    for ts, p in preempts_total:
        if last_p is not None and p > last_p:
            ax.axvline(to_dt(ts), color="#9467bd", ls="-", lw=0.6, alpha=0.4)
        last_p = p

    ax.xaxis.set_major_formatter(mdates.DateFormatter("%H:%M\n%m-%d"))
    ax.grid(alpha=0.3)
    n_sig = len(sigterms)
    n_start = len(starts)
    n_pre = sum(1 for i in range(1, len(preempts_total))
                if preempts_total[i][1] > preempts_total[i - 1][1]) if preempts_total else 0
    ax.set_title(f"{name}  ·  {n_sig} sigterms, {n_start} starts, "
                 f"{n_pre} cluster-preempt jumps")

    handles = []
    if step_pts: handles.append(plt.Line2D([], [], color="#1f77b4", label="step"))
    if train_loss: handles.append(plt.Line2D([], [], color="#d62728", alpha=0.6, label="train/loss"))
    handles += [
        plt.Line2D([], [], color="#ff7f0e", ls="--", label=f"trainer_started ({n_start})"),
        plt.Line2D([], [], color="#7f7f7f", ls=":", label=f"sigterm ({n_sig})"),
        plt.Line2D([], [], color="#9467bd", ls="-", alpha=0.5, label=f"cluster preempt ({n_pre})"),
    ]
    ax.legend(handles=handles, loc="lower right", fontsize=9, framealpha=0.85)
    fig.autofmt_xdate()

    out_path = Path(out) if out else PROJECT_ROOT / "plots" / "wallclock" / f"{name}.png"
    out_path.parent.mkdir(parents=True, exist_ok=True)
    fig.tight_layout()
    fig.savefig(out_path, dpi=130)
    plt.close(fig)
    print(f"wrote: {out_path}")
    print(f"  steps logged: {len(step_pts)}  range: "
          f"{step_pts[0][1] if step_pts else '-'} → {step_pts[-1][1] if step_pts else '-'}")
    print(f"  events: {n_start} starts, {n_sig} sigterms, {n_pre} cluster-preempt jumps")

    if upload:
        run = wandb.init(
            entity=WANDB_PROJECT.split("/")[0],
            project=WANDB_PROJECT.split("/")[-1],
            id=name, resume="allow",
        )
        run.summary["summary/wallclock_overlay"] = wandb.Image(str(out_path))
        run.finish()
        print(f"  uploaded to wandb run {name} as summary/wallclock_overlay")


