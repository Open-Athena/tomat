def _wb_exec(query: str, **variables):
    """Execute a raw GraphQL query against wandb.

    Uses `requests` directly (wandb's bundled `wandb_gql` has a fragile
    transitive vendor layout that doesn't survive being imported by an
    external script). API key resolution mirrors `wandb.Api()` — env var,
    then `~/.netrc`.
    """
    import netrc
    import requests
    key = os.environ.get("WANDB_API_KEY")
    host = os.environ.get("WANDB_BASE_URL", "https://api.wandb.ai")
    if not key:
        try:
            auths = netrc.netrc().authenticators(host.split("//", 1)[-1])
            if auths:
                key = auths[2]
        except (FileNotFoundError, netrc.NetrcParseError):
            pass
    if not key:
        err("set WANDB_API_KEY or `wandb login`")
        sys.exit(1)
    r = requests.post(
        f"{host}/graphql",
        json={"query": query, "variables": variables or {}},
        auth=("api", key),
        timeout=30,
    )
    r.raise_for_status()
    body = r.json()
    if body.get("errors"):
        raise RuntimeError(json.dumps(body["errors"], indent=2))
    return body["data"]


@cli.group("cache")
def cache_grp():
    """Manage Levanter caches: build, mirror across regions, list."""


# Canonical source bucket (where cache-build originally produces the cache).
_CACHE_SRC_DEFAULT = "gs://marin-eu-west4/tomat"
# Target buckets we mirror the cache to so we have region-local data in
# every zone iris might schedule us into. Avoids the "cross-region IO
# halves MFU" problem when iris picks a zone we don't have cache in.
# Map: bucket → zone(s) it serves.
_CACHE_TARGETS = {
    "gs://marin-us-central1/tomat": ["us-central1-a (v5p)"],
    "gs://marin-us-east1/tomat":    ["us-east1-d (v6e)"],
    "gs://marin-us-east5/tomat":    ["us-east5-a (v5p)", "us-east5-b (v6e)"],
}


@cache_grp.command("mirror")
@click.option("-l", "--data-label", default="train-full-v3", help="data label whose cache to mirror")
@click.option("-s", "--source", default=_CACHE_SRC_DEFAULT, show_default=True, help="canonical source bucket")
@click.option("-t", "--targets", default=None, help="comma-separated target bucket prefixes (default: all known regional targets)")
@click.option("--splits", default="train,validation", show_default=True, help="comma-separated split names under the cache root")
@click.option("-d", "--dry-run", is_flag=True, help="print rsync commands without running")
def cache_mirror(data_label: str, source: str, targets: str | None, splits: str, dry_run: bool):
    """Mirror `<source>/cache/<data_label>/{split}/` to each target via `gsutil rsync`.

    Idempotent — re-running skips files that already exist with matching size+md5.
    Sizes are typically dominated by `<split>/input_ids/` (~50 GB for train-full-v3).
    """
    tgt_list = (
        [t.strip() for t in targets.split(",") if t.strip()]
        if targets else list(_CACHE_TARGETS.keys())
    )
    split_list = [s.strip() for s in splits.split(",") if s.strip()]
    print(f"[cache mirror] data_label={data_label} source={source}")
    for tgt in tgt_list:
        note = _CACHE_TARGETS.get(tgt, ["(custom)"])
        print(f"  → {tgt}  ({', '.join(note)})")
    print(f"  splits: {split_list}")

    for tgt in tgt_list:
        for split in split_list:
            src = f"{source}/cache/{data_label}/{split}/"
            dst = f"{tgt}/cache/{data_label}/{split}/"
            cmd = ["gsutil", "-m", "rsync", "-r", src, dst]
            print()
            print(f"# {src} → {dst}")
            print(" ", " ".join(cmd))
            if dry_run:
                continue
            r = subprocess.run(cmd)
            if r.returncode != 0:
                err(f"[FAIL] gsutil rsync rc={r.returncode}; aborting mirror")
                sys.exit(r.returncode)


@cache_grp.command("build")
@click.option("-l", "--data-label", default="train-full-v3", help="data label whose cache to build")
@click.option("--bucket", default=None, help=f"bucket where the cache should land (default: {GCS_BUCKET})")
@click.option("--lmq-path", default=None, help="TOMAT_LMQ_PATH (default = {bucket}/codecs/lmq-v2-16k.npz)")
@click.option("--cpu", default=16, type=int, help="iris --cpu")
@click.option("--memory", default="64GB", show_default=True, help="iris --memory")
@click.option("--zone", default=None, help="iris --zone (e.g. europe-west4-a); pin to keep the build local to the cache region.")
@click.option("--region", default=None, help="iris --region (e.g. europe-west4).")
@click.option("-e", "--env", "extra_env", multiple=True, help="extra env var KEY=VAL")
@click.option("-d", "--dry-run", is_flag=True, help="print iris cmd without firing")
def cache_build(
    data_label: str,
    bucket: str | None,
    lmq_path: str | None,
    cpu: int,
    memory: str,
    zone: str | None,
    region: str | None,
    extra_env: tuple[str, ...],
    dry_run: bool,
):
    """Build a Levanter cache from tokenized parquets without burning TPU time.

    Fires a CPU-only iris job that runs `train_tomat_tpu.py` with
    `TOMAT_BUILD_CACHE_ONLY=1` — short-circuits before `train_lm_main`,
    materializes `cache/<data_label>/{train,validation}/`, exits.

    Use this once per (data_label, bucket) — chains naturally after the
    Modal tokenize pipeline, decouples build from train, avoids the
    "trainer dies mid-build and leaves the cache half-built" failure mode.
    """
    bucket = bucket or GCS_BUCKET
    lmq_path = lmq_path or f"{bucket}/codecs/lmq-v2-16k.npz"
    wandb_key = os.environ.get("WANDB_API_KEY", "<WANDB_API_KEY>")
    job_name = f"cache-build-{data_label}-{bucket.rsplit('/', 1)[0].rsplit('-', 1)[-1]}"

    env_vars: list[tuple[str, str]] = [
        ("WANDB_API_KEY", wandb_key),
        ("TOMAT_BUCKET", bucket),
        ("TOMAT_LABEL", data_label),
        ("TOMAT_RESULTS_LABEL", job_name),
        ("TOMAT_MODEL", "200M"),       # only used to build the LmDataConfig; doesn't affect cache contents
        ("TOMAT_STEPS", "1"),          # ditto
        ("TOMAT_BATCH_SIZE", "128"),
        ("TOMAT_SEED", "42"),
        ("TOMAT_LMQ_PATH", lmq_path),
        ("TOMAT_DENSITY_LOSS_TYPE", "emd"),
        ("TOMAT_DENSITY_ONLY_LOSS", "1"),
        ("TOMAT_LR", "3e-4"),
        ("TOMAT_LR_SCHEDULE", "constant"),
        ("TOMAT_WARMUP", "0.05"),
        ("TOMAT_VAL_SEQS", "256"),
        ("TOMAT_PROFILE", "0"),
        ("TOMAT_GRADIENT_CHECKPOINTING", "1"),
        ("TOMAT_CACHE_DIR", f"{bucket}/cache/{data_label}/"),
        ("TOMAT_BUILD_CACHE_ONLY", "1"),
        ("MARIN_I_WILL_PAY_FOR_ALL_FEES", "1"),
    ]
    for kv in extra_env:
        if "=" not in kv:
            err(f"--env {kv!r}: expected KEY=VAL")
            sys.exit(1)
        k, v = kv.split("=", 1)
        env_vars.append((k, v))

    cmd = [
        "uv", "run", "iris", "--cluster=marin", "job", "run",
        "--cpu", str(cpu), "--memory", memory,
    ]
    for z in (zone or "").split(","):
        if z := z.strip():
            cmd += ["--zone", z]
    for r in (region or "").split(","):
        if r := r.strip():
            cmd += ["--region", r]
    for k, v in env_vars:
        cmd += ["--env-vars", k, v]
    cmd += [
        "--no-wait", "--no-terminate-on-exit",
        "--job-name", job_name,
        "--", "python", "train_tomat_tpu.py",
    ]
    if dry_run:
        pretty = " ".join("'<WANDB_API_KEY>'" if a == wandb_key else a for a in cmd)
        print(f"# {job_name} (cache-build only)")
        print(f"  cd {MARIN_DIR}")
        print(f"  {pretty}")
        return
    if wandb_key == "<WANDB_API_KEY>":
        err("WANDB_API_KEY not set in env")
        sys.exit(1)
    r = subprocess.run(cmd, cwd=str(MARIN_DIR), capture_output=True, text=True)
    if r.returncode != 0:
        err(f"[FAIL launch {job_name}] rc={r.returncode}\n{r.stderr[-1000:]}")
        sys.exit(r.returncode)
    print(f"[launched cache-build {job_name} → {bucket}/cache/{data_label}/]")


@cli.group("wb")
def wb_grp():
    """Wandb GraphQL helpers: introspect, list projects, manipulate access."""


@wb_grp.command("whoami")
@click.option("-k", "--key", default=None,
              help="api key to probe (default: $WANDB_API_KEY)")
@click.option("--list-keys", is_flag=True, help="also list this user's other API keys")
def wb_whoami(key: str | None, list_keys: bool):
    """Identify the user + default entity + teams behind an API key.

    Useful when juggling multiple `WANDB_API_KEY` values in .envrc — wandb
    keys are per-user, NOT per-org, so this also surfaces what's reachable
    rather than what's "scoped".
    """
    prev_key = os.environ.get("WANDB_API_KEY")
    if key:
        os.environ["WANDB_API_KEY"] = key
    try:
        q = """{ viewer {
          username email
          defaultEntity { name }
          organizations { name }
          teams(first: 50) { edges { node { name organization { name } } } }
        """ + ("apiKeys { edges { node { name } } } " if list_keys else "") + "} }"
        out = _wb_exec(q)
        v = out["viewer"]
    finally:
        if key:
            if prev_key is None:
                os.environ.pop("WANDB_API_KEY", None)
            else:
                os.environ["WANDB_API_KEY"] = prev_key
    print(f"user:          {v['username']} <{v['email']}>")
    de = (v.get("defaultEntity") or {}).get("name")
    print(f"defaultEntity: {de}")
    print("orgs:")
    for o in v.get("organizations") or []:
        print(f"  {o['name']}")
    print("teams:")
    for e in v.get("teams", {}).get("edges", []):
        n = e["node"]
        org = (n.get("organization") or {}).get("name") or "-"
        print(f"  {n['name']:30s}  org={org}")
    if list_keys:
        keys = [e["node"]["name"] for e in v.get("apiKeys", {}).get("edges", [])]
        print(f"keys: {len(keys)}")
        for k in keys:
            print(f"  {k}")


@wb_grp.command("projects")
@click.option("-e", "--entity", default="PrinceOA", help="wandb entity")
@click.option("-f", "--filter", "filt", default=None, help="case-insensitive substring filter on project name")
def wb_projects(entity: str, filt: str | None):
    """List projects under ENTITY with current access level."""
    out = _wb_exec(
        "query Q($e: String!) { models(entityName: $e, first: 500) "
        "{ edges { node { name access createdAt id } } } }",
        e=entity,
    )
    rows = [e["node"] for e in out["models"]["edges"]]
    if filt:
        rows = [r for r in rows if filt.lower() in r["name"].lower()]
    rows.sort(key=lambda r: r["createdAt"], reverse=True)
    print(f"# {len(rows)} projects in {entity}" + (f" matching {filt!r}" if filt else ""))
    for r in rows:
        print(f"  {r['access']:8s}  {r['name']}")


@wb_grp.command("access")
@click.option("-e", "--entity", default="PrinceOA")
@click.option("--set", "set_to", default=None,
              help="if given, attempt to upsert access (e.g. USER_READ, PRIVATE)")
@click.argument("project")
def wb_access(entity: str, project: str, set_to: str | None):
    """Get or set a single project's `access` field via upsertModel."""
    out = _wb_exec(
        "query Q($e: String!, $n: String!) { project(entityName: $e, name: $n) "
        "{ name access entityName id } }",
        e=entity, n=project,
    )
    p = out["project"]
    if p is None:
        err(f"project {entity}/{project} not found (or no access)")
        sys.exit(1)
    print(f"current: {p['access']}  ({entity}/{project})")
    if set_to is None:
        return
    try:
        res = _wb_exec(
            "mutation M($n: String!, $e: String!, $a: String!) "
            "{ upsertModel(input: { name: $n, entityName: $e, access: $a }) "
            "{ project { name access } } }",
            n=project, e=entity, a=set_to,
        )
        new = res["upsertModel"]["project"]
        print(f"new:     {new['access']}  ({entity}/{new['name']})")
    except Exception as e:
        err(f"upsertModel failed: {e}")
        sys.exit(2)


@wb_grp.command("move")
@click.option("-s", "--src", default="PrinceOA", help="source entity")
@click.option("-d", "--dst", default="open-athena", help="destination entity")
@click.option("-n", "--dry-run", is_flag=True, help="print mutation without executing")
@click.argument("projects", nargs=-1, required=True)
def wb_move(src: str, dst: str, projects: tuple[str, ...], dry_run: bool):
    """Move PROJECTS from `--src` entity to `--dst` entity via moveProjects."""
    print(f"# moveProjects: {src} → {dst}")
    for p in projects:
        print(f"  {p}")
    if dry_run:
        print("# (dry-run; not executing)")
        return
    try:
        res = _wb_exec(
            "mutation M($i: MoveProjectsInput!) "
            "{ moveProjects(input: $i) { clientMutationId } }",
            i={
                "sourceEntityName": src,
                "destinationEntityName": dst,
                "projectNames": list(projects),
                "ownerUsername": _wb_exec("{ viewer { username } }")["viewer"]["username"],
            },
        )
        print(f"# done: {res}")
    except Exception as e:
        err(f"moveProjects failed: {e}")
        sys.exit(2)


@wb_grp.command("mutations")
@click.argument("filt", required=False)
def wb_mutations(filt: str | None):
    """List GraphQL mutations, optionally filtered by substring."""
    out = _wb_exec(
        "{ __schema { mutationType { fields { name args { name } } } } }"
    )
    muts = out["__schema"]["mutationType"]["fields"]
    if filt:
        muts = [m for m in muts if filt.lower() in m["name"].lower()]
    print(f"# {len(muts)} mutations" + (f" matching {filt!r}" if filt else ""))
    for m in muts:
        args = ", ".join(a["name"] for a in m["args"])
        print(f"  {m['name']}({args})")


@wb_grp.command("type")
@click.argument("type_name")
def wb_type(type_name: str):
    """Introspect a GraphQL type or input object's fields."""
    out = _wb_exec(
        "query Q($n: String!) { __type(name: $n) { name kind "
        "fields { name type { name kind ofType { name kind } } } "
        "inputFields { name type { name kind ofType { name kind } } } } }",
        n=type_name,
    )
    t = out["__type"]
    if not t:
        err(f"type {type_name!r} not found")
        sys.exit(1)
    fields = t.get("fields") or t.get("inputFields") or []
    print(f"# {t['kind']} {t['name']}  ({len(fields)} fields)")
    for f in fields:
        ty = f["type"]
        nm = ty["name"] or (ty["ofType"] and ty["ofType"]["name"]) or ty["kind"]
        print(f"  {f['name']}: {nm}")


@wb_grp.command("gql")
@click.option("-v", "--var", multiple=True, metavar="KEY=VAL",
              help="GraphQL variable (repeatable); VAL is parsed as JSON, falling back to string")
@click.argument("query")
def wb_gql(query: str, var: tuple[str, ...]):
    """Execute a raw GraphQL query/mutation against wandb.

    QUERY may be `-` to read from stdin, or a path to a `.graphql` file,
    or the literal query string.
    """
    if query == "-":
        query = sys.stdin.read()
    elif query.endswith(".graphql") and Path(query).exists():
        query = Path(query).read_text()
    variables = {}
    for kv in var:
        k, _, v = kv.partition("=")
        try:
            variables[k] = json.loads(v)
        except json.JSONDecodeError:
            variables[k] = v
    out = _wb_exec(query, **variables)
    print(json.dumps(out, indent=2))


@cli.command("cost")
@click.option("-p", "--prefix", default="/ryan", help="iris job prefix to inspect")
@click.option("-f", "--filter", "filter_re", default="tomat|train-full|train-cont", help="regex on job name")
def cost(prefix: str, filter_re: str):
    """Estimate MSRP-equivalent compute spend across matching iris jobs.

    Sums chip-hours (TPU × duration) across visible parent jobs and prints
    preempt-rate and on-demand-rate equivalents. Public-rate, not actual.
    """
    # Parent jobs only — children inherit their parent's slice, would double-count.
    res = iris_run("list", "--prefix", prefix)
    out = strip_iris_log(res.stdout)
    pat = re.compile(filter_re)
    rows = []
    for line in out.split("\n"):
        if not line.strip() or "JOB ID" in line:
            continue
        jid = line.split()[0]
        if not jid.startswith("/") or jid.count("/") > 2:
            continue
        if not pat.search(jid):
            continue
        # Pull TPU + duration from the line — parsing is fragile, so summary
        # call would be more robust; defer until we build a json list option.
        m = re.search(r"v6e-(\d+)", line)
        chips = int(m.group(1)) if m else 0
        rows.append((jid, chips, line))
    if not rows:
        err(f"no matching jobs under {prefix!r}")
        sys.exit(0)

    print(f"# Jobs (prefix={prefix}, filter={filter_re}):")
    print(f"  found {len(rows)} parent jobs (chip-hour estimates require `iris job summary` per-job)")
    for jid, chips, _ in rows:
        print(f"  v6e-{chips:<3d}  {jid}")
    print()
    print(f"# Public TPU rates (v6e):")
    print(f"  preempt   ${PRICE_PREEMPT:.2f}/chip-hr")
    print(f"  on-demand ${PRICE_ONDEMAND:.2f}/chip-hr")
    print()
    print("(For per-job chip-hour totals, run `tomat iris summary <jid>` and")
    print(" multiply chips × wall-clock manually. Auto-summing TBD.)")


