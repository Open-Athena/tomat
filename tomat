#!/usr/bin/env python3
"""tomat — project-management CLI.

Wraps wandb + iris + GCS into a single tool for the recurring operations
in the tomat training project. Subcommands:

  tomat runs ls                      list wandb runs in tomat-lmq-P14
  tomat runs status [<substr>]       state, MFU, step, loss for one/all runs
  tomat runs nmae <substr>           mat-NMAE curve as a table

  tomat iris ls                      list /ryan/* iris jobs (filtered)
  tomat iris kill <substr>           kill matching running jobs
  tomat iris logs <substr>           tail logs for a job
  tomat iris summary <substr>        per-task summary

  tomat evals fire <run> -s STEPS    fire mat-NMAE evals against ckpts
  tomat evals harvest <run>          start watchdog harvesters

  tomat train LABEL [-r] ...         launch (or resume) a training run

  tomat cost                         MSRP-equivalent table for project

Conventions:
  RUN_LABEL    wandb display name == iris job name == GCS results dir
  SUBSTR       case-sensitive substring match against RUN_LABEL
"""
from __future__ import annotations

import os
import re
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path

import click


WANDB_PROJECT = "PrinceOA/tomat-lmq-P14"
GCS_BUCKET = "gs://marin-eu-west4/tomat"
LMQ_PATH = f"{GCS_BUCKET}/codecs/lmq-v2-16k.npz"
PROJECT_ROOT = Path(__file__).resolve().parent
MARIN_DIR = PROJECT_ROOT / "marin"
TMP_DIR = PROJECT_ROOT / "tmp"

SPLITS = {
    "val_200": "validation",
    "train_200": "train",
    "val_400b": "validation",
    "train_400b": "train",
}


def err(*a, **k):
    print(*a, file=sys.stderr, **k)


def fmt(x):
    return f"{x:5.2f}" if isinstance(x, (int, float)) else "  -  "


def match_runs(api, substr: str | None):
    runs = list(api.runs(WANDB_PROJECT))
    if substr is None:
        return runs
    return [r for r in runs if substr in r.name]


def require_one(runs, substr: str):
    if not runs:
        err(f"no runs match {substr!r}")
        sys.exit(1)
    if len(runs) > 1:
        err(f"multiple runs match {substr!r}:")
        for r in runs:
            err(f"  {r.name}")
        sys.exit(1)
    return runs[0]


def iris_run(*args: str, capture: bool = True, timeout: int = 180) -> subprocess.CompletedProcess:
    """Invoke `uv run iris --cluster=marin job <args>` from marin/."""
    cmd = ["uv", "run", "iris", "--cluster=marin", "job", *args]
    return subprocess.run(
        cmd,
        cwd=str(MARIN_DIR),
        capture_output=capture,
        text=True,
        timeout=timeout,
    )


def strip_iris_log(text: str) -> str:
    """Drop iris's `I20...` log lines so output is parseable."""
    return "\n".join(l for l in text.split("\n") if not l.startswith("I20"))


# iris requires --prefix to be `/<user>/<jobname>` (2+ segments). We fan
# out across the conventional job-name prefixes used in tomat work.
DEFAULT_IRIS_PREFIXES = ("/ryan/tomat", "/ryan/train", "/ryan/eval")


def iris_list_lines(prefixes: tuple[str, ...] = DEFAULT_IRIS_PREFIXES, state: str | None = None) -> list[str]:
    """Pull `iris job list` lines across multiple prefixes, deduped.

    Note: SEQUENTIAL on purpose. Each `iris` invocation establishes its
    own SSH tunnel on local port 10000; running them concurrently makes
    them fight for the port and serializes anyway (worse — `iris ls`
    measured at 49 s parallel vs 6 s sequential).
    """
    seen: set[str] = set()
    out_lines: list[str] = []
    for p in prefixes:
        args = ["list", "--prefix", p]
        if state:
            args += ["--state", state]
        res = iris_run(*args)
        if res.returncode != 0:
            continue
        for line in strip_iris_log(res.stdout).split("\n"):
            if not line.strip() or "JOB ID" in line:
                continue
            jid = line.split()[0] if line else ""
            if not jid.startswith("/") or jid in seen:
                continue
            seen.add(jid)
            out_lines.append(line)
    return out_lines


